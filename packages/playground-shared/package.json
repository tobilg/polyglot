{
  "name": "playground-shared",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./sql": {
      "types": "./src/sql.ts",
      "default": "./dist/sql.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@polyglot-sql/sdk": "^0.1.11"
  },
  "devDependencies": {
    "rimraf": "^3.0.2",
    "typescript": "^5.7.0"
  }
}
