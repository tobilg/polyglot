      "description": "ADD_SECONDS to DATE_ADD"
    },
    {
      "sql": "SELECT ADD_YEARS(d, 1) FROM t",
      "write": { "trino": "SELECT DATE_ADD('year', 1, d) FROM t" },
      "description": "ADD_YEARS to DATE_ADD"
    },
    {
      "sql": "SELECT add_days(d, 7) FROM t",
