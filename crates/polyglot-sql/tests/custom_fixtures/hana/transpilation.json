    },
    {
      "sql": "SELECT DAYS_BETWEEN(start_date, end_date) AS duration FROM events",
      "write": { "trino": "SELECT DATE_DIFF('day', start_date, end_date) AS duration FROM events" },
      "description": "DAYS_BETWEEN with column expressions"
    },

