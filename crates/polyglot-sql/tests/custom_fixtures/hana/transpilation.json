{
  "dialect": "hana",
  "category": "transpilation",
  "identity": [],
  "transpilation": [
    {
      "sql": "SELECT ADD_DAYS(CURRENT_DATE, 7) FROM t",
      "write": { "trino": "SELECT DATE_ADD('day', 7, CURRENT_DATE) FROM t" },
      "description": "ADD_DAYS to DATE_ADD"
    },
    {
      "sql": "SELECT ADD_DAYS(d, -1) FROM t",
      "write": { "trino": "SELECT DATE_ADD('day', -1, d) FROM t" },
      "description": "ADD_DAYS with negative value"
    },
    {
      "sql": "SELECT ADD_DAYS(d, 0) FROM t",
      "write": { "trino": "SELECT DATE_ADD('day', 0, d) FROM t" },
      "description": "ADD_DAYS with zero"
    },
    {
      "sql": "SELECT UPPER(ADD_DAYS(d, 7)) FROM t",
      "write": { "trino": "SELECT UPPER(DATE_ADD('day', 7, d)) FROM t" },
      "description": "ADD_DAYS nested in another function"
    },
    {
      "sql": "SELECT * FROM t WHERE d > ADD_DAYS(CURRENT_DATE, -30)",
      "write": { "trino": "SELECT * FROM t WHERE d > DATE_ADD('day', -30, CURRENT_DATE)" },
      "description": "ADD_DAYS in WHERE clause"
    },
    {
      "sql": "SELECT ADD_MONTHS(CURRENT_DATE, 3) FROM t",
