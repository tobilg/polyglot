def transpile(
    sql: str,
    read: str | None = None,
    write: str | None = None,
    *,
    identity: bool = True,
    error_level: str | None = None,
    pretty: bool = False,
) -> list[str]:
    """Transpile SQL from one dialect to another.

    Args:
        sql: One or more SQL statements separated by semicolons.
        read: Source dialect (e.g. ``"mysql"``). Defaults to ``"generic"``.
        write: Target dialect (e.g. ``"postgres"``). Defaults to ``"generic"``.
        identity: Keep SQL unchanged when read == write. Defaults to ``True``.
        error_level: Error handling: ``"raise"`` (default), ``"warn"``, or ``"ignore"``.
        pretty: Emit formatted SQL with indentation.

    Returns:
        A list of transpiled SQL strings (one per statement).

    Raises:
        TranspileError: If transpilation fails.
        ValueError: If a dialect name is unknown.
    """
    ...


def parse(
    sql: str,
    read: str | None = None,
    dialect: str | None = None,
    *,
    error_level: str | None = None,
) -> list[Expression]:
    """Parse SQL into a list of ``Expression`` AST nodes.

    Args:
        sql: One or more SQL statements separated by semicolons.
        read: Source dialect. Alias for *dialect*.
        dialect: Source dialect (e.g. ``"postgres"``). Defaults to ``"generic"``.
        error_level: ``"raise"`` (default), ``"warn"``, or ``"ignore"``.

    Returns:
        A list of typed ``Expression`` objects (e.g. ``Select``, ``Insert``).

    Raises:
        ParseError: If parsing fails and *error_level* is ``"raise"``.
        ValueError: If the dialect name is unknown.
    """
    ...


def parse_one(
    sql: str,
    read: str | None = None,
    dialect: str | None = None,
    *,
    into: Any | None = None,
    error_level: str | None = None,
) -> Expression:
    """Parse a single SQL statement into an ``Expression`` AST node.

    Args:
        sql: Exactly one SQL statement.
        read: Source dialect. Alias for *dialect*.
        dialect: Source dialect (e.g. ``"postgres"``). Defaults to ``"generic"``.
        into: Reserved for future use.
        error_level: ``"raise"`` (default), ``"warn"``, or ``"ignore"``.

    Returns:
        A typed ``Expression`` object (e.g. ``Select``).

    Raises:
        ParseError: If the input contains zero or multiple statements.
        ValueError: If the dialect name is unknown.
    """
    ...


def generate(
    ast: Expression | dict[str, Any] | list[Expression] | list[dict[str, Any]],
    dialect: str = "generic",
    *,
    pretty: bool = False,
) -> list[str]:
    """Generate SQL strings from AST nodes.

    Accepts a single ``Expression``, a list of ``Expression`` objects, or
    their ``dict`` equivalents (as returned by :meth:`Expression.to_dict`).

    Args:
        ast: One or more AST nodes.
        dialect: Target dialect. Defaults to ``"generic"``.
        pretty: Emit formatted SQL with indentation.

    Returns:
        A list of SQL strings (one per input AST).

    Raises:
        GenerateError: If generation fails.
        ValueError: If the dialect name is unknown.
    """
    ...


def format_sql(
    sql: str,
    dialect: str = "generic",
    *,
    max_input_bytes: int | None = None,
    max_tokens: int | None = None,
    max_ast_nodes: int | None = None,
    max_set_op_chain: int | None = None,
) -> str:
    """Parse and pretty-print SQL (identity transpile with formatting).

    Args:
        sql: A single SQL statement.
        dialect: Dialect for parsing and generation. Defaults to ``"generic"``.
        max_input_bytes: Override the input size limit (bytes).
        max_tokens: Override the token count limit.
        max_ast_nodes: Override the AST node count limit.
        max_set_op_chain: Override the ``UNION``/``INTERSECT``/``EXCEPT`` chain limit.

    Returns:
        Formatted SQL string.

    Raises:
        ParseError: If parsing fails or a guard limit is exceeded.
        ValueError: If the dialect name is unknown.
    """
    ...


