from typing import Any


class PolyglotError(Exception):
    """Base exception for all polyglot-sql errors."""
    ...

class ParseError(PolyglotError):
    """Raised when SQL parsing fails."""
    ...

class GenerateError(PolyglotError):
    """Raised when SQL generation from an AST fails."""
    ...

class TranspileError(PolyglotError):
    """Raised when SQL transpilation fails."""
    ...

class ValidationError(PolyglotError):
    """Raised when SQL validation encounters a fatal error."""
    ...


class ValidationErrorInfo:
    """Details about a single validation finding."""

    @property
    def message(self) -> str:
        """Human-readable description of the issue."""
        ...

    @property
    def line(self) -> int:
        """1-based line number where the issue was found."""
        ...

    @property
    def col(self) -> int:
        """1-based column number where the issue was found."""
        ...

    @property
    def code(self) -> str:
        """Machine-readable error code (e.g. ``"E001"``)."""
        ...

    @property
    def severity(self) -> str:
        """Severity level: ``"error"`` or ``"warning"``."""
        ...


class ValidationResult:
    """Result returned by :func:`validate`."""

    @property
    def valid(self) -> bool:
        """``True`` when the SQL is syntactically valid."""
        ...

    @property
    def errors(self) -> list[ValidationErrorInfo]:
        """List of validation findings (may be empty when valid)."""
        ...

    def __bool__(self) -> bool:
        """Allows ``if validate(...):`` usage."""
        ...


class Expression:
    """Base class for all AST nodes.

    Every parsed SQL expression is represented as an ``Expression`` subclass
    (e.g. ``Select``, ``Column``, ``Literal``).  All subclasses share the
    properties and methods defined here.

    The API mirrors `sqlglot <https://github.com/tobymao/sqlglot>`_ so that
    porting code between the two libraries is straightforward.

    Example::

        import polyglot_sql

        ast = polyglot_sql.parse_one("SELECT a AS x, b FROM t WHERE c > 1")

        # Property access
        ast.expressions          # [Column(a), Column(b)]  (AS x is an Alias wrapping Column)
        ast.find(polyglot_sql.Column).name   # "a"

        # Type dispatch
        isinstance(ast, polyglot_sql.Select)  # True

        # Traversal
        for node in ast.walk():
            print(node.kind, node.name)
    """

    # ── Core identifiers ─────────────────────────────────────────────

    @property
    def kind(self) -> str:
        """Snake-case variant name, e.g. ``"select"``, ``"column"``, ``"add"``.

        Matches the key in :meth:`to_dict` output and corresponds to the
        serde tag of the underlying Rust enum variant.
        """
        ...

    @property
    def key(self) -> str:
        """Alias for :attr:`kind` (sqlglot compatibility)."""
        ...

    @property
    def tree_depth(self) -> int:
        """Maximum depth of the sub-tree rooted at this node (0 for leaves)."""
        ...

    # ── SQL generation ───────────────────────────────────────────────

    def sql(self, dialect: str | None = None, *, pretty: bool = False) -> str:
        """Generate a SQL string for this expression.

        Args:
            dialect: Target dialect (e.g. ``"postgres"``, ``"mysql"``).
                     Defaults to ``"generic"`` (dialect-agnostic SQL).
            pretty: When ``True``, emit formatted SQL with indentation.

        Returns:
            The SQL string.

        Raises:
            GenerateError: If generation fails.
            ValueError: If the dialect name is unknown.
        """
        ...

    # ── Serialization ────────────────────────────────────────────────

    def to_dict(self) -> dict[str, Any]:
        """Serialize this node to a nested Python dict (JSON-like).

        The top-level key is the :attr:`kind` string and the value is a dict
        of the node's fields.

        Example::

            polyglot_sql.parse_one("SELECT 1").to_dict()
            # {"select": {"expressions": [{"literal": {"value": "1", ...}}], ...}}
        """
        ...

    def arg(self, name: str) -> Any:
        """Look up a single field by name from the serialized payload.

        Returns a Python object: child ``Expression`` objects are wrapped
        automatically; scalars are returned as ``str`` / ``int`` / ``bool``;
        missing keys return ``None``.
        """
        ...

    # ── Child accessors (no serialization, fast) ─────────────────────

    @property
    def this(self) -> Expression | None:
        """Primary child expression.

        For unary operators and functions this is the operand.
        For binary operators this is the *left* operand.
        For ``Alias`` this is the aliased expression.
        For clauses (``Where``, ``Having``, ...) this is the predicate.

        Returns ``None`` for leaf nodes and types without a primary child
        (e.g. ``Select``, ``Identifier``, ``Literal``).
        """
        ...

    @property
    def expression(self) -> Expression | None:
        """Secondary child expression.

        For binary operators this is the *right* operand.
        For ``BinaryFunc`` types (``Power``, ``NullIf``, ...) this is the
        second argument.

        Returns ``None`` for most other node types.
        """
        ...

    @property
    def expressions(self) -> list[Expression]:
        """List of child expressions.

        - ``Select.expressions`` — the selected columns
        - ``Function.expressions`` / ``AggregateFunction.expressions`` — arguments
        - ``From.expressions`` — tables in the FROM clause
        - ``In.expressions`` — values in an IN list
        - ``Array`` / ``Tuple`` / ``Coalesce`` / ``Greatest`` / ``Least`` — elements

        Returns an empty list for node types without a list child.
        """
        ...

    @property
    def args(self) -> dict[str, Any]:
        """All fields as a dict (uses serialization, not on the hot path).

        Keys are field names, values are Python objects.
        """
        ...

    @property
    def name(self) -> str:
        """Short name of this expression.

        - ``Column`` → column name (e.g. ``"id"``)
        - ``Table`` → table name (e.g. ``"users"``)
        - ``Identifier`` → identifier text
        - ``Literal`` → literal value as string (e.g. ``"42"``)
        - ``Function`` / ``AggregateFunction`` → function name
        - ``Star`` → ``"*"``
        - ``Alias`` → delegates to the aliased expression's name
        - ``Boolean`` → ``"TRUE"`` / ``"FALSE"``
        - ``Null`` → ``"NULL"``

        Returns ``""`` for types without a meaningful name.
        """
        ...

    @property
    def alias(self) -> str:
        """Alias name, if this expression has one.

        - ``Alias`` → the alias identifier (e.g. ``"x"`` in ``a AS x``)
        - ``Table`` → table alias if present
        - ``Subquery`` → subquery alias if present

        Returns ``""`` otherwise.
        """
        ...

    @property
    def alias_or_name(self) -> str:
        """Returns :attr:`alias` if non-empty, else :attr:`name`."""
        ...

    @property
    def output_name(self) -> str:
        """The name this expression produces in a result set.

        - ``Alias`` → the alias identifier
        - ``Column`` → the column name
        - ``Literal`` → the literal value
        - ``Star`` → ``"*"``

        Returns ``""`` for types without an output name.
        """
        ...

    @property
    def comments(self) -> list[str]:
        """SQL comments attached to this node (trailing or leading)."""
        ...

    @property
    def type_(self) -> Expression | None:
        """Inferred data type (a ``DataType`` expression), or ``None``."""
        ...

    # ── Type predicates ──────────────────────────────────────────────

    @property
    def is_string(self) -> bool:
        """``True`` if this is a string literal."""
        ...

    @property
    def is_number(self) -> bool:
        """``True`` if this is a numeric literal (or negated numeric literal)."""
        ...

    @property
    def is_int(self) -> bool:
        """``True`` if this is an integer literal (or negated integer literal)."""
        ...

    @property
    def is_star(self) -> bool:
        """``True`` if this is a ``*`` (star / wildcard) expression."""
        ...

    def is_leaf(self) -> bool:
        """``True`` if this node has no children."""
        ...

    # ── Parent tracking ──────────────────────────────────────────────

    @property
    def parent(self) -> Expression | None:
        """The parent node, or ``None`` for root nodes.

        Parent references are set lazily when accessing children via
        :attr:`this`, :attr:`expression`, :attr:`expressions`,
        or :meth:`children`.
        """
        ...

    @property
    def depth(self) -> int:
        """Number of parent hops to the root (0 for root nodes)."""
        ...

    def root(self) -> Expression:
        """Walk the parent chain and return the root node."""
        ...

    def find_ancestor(self, *types: type[Expression] | str) -> Expression | None:
        """Walk the parent chain and return the first ancestor matching any of *types*.

        Args:
            *types: One or more ``Expression`` subclasses or snake-case kind strings.

        Returns:
            The matching ancestor, or ``None``.
        """
        ...

    @property
    def parent_select(self) -> Expression | None:
        """Shorthand for ``find_ancestor(Select)``."""
        ...

    # ── Traversal ────────────────────────────────────────────────────

    def children(self) -> list[Expression]:
        """Immediate child expressions (with parent references set)."""
        ...

    def walk(self, order: str = "dfs") -> list[Expression]:
        """Traverse the entire sub-tree.

        Args:
            order: ``"dfs"`` (depth-first, default) or ``"bfs"`` (breadth-first).

        Returns:
            All nodes including ``self``.

        Raises:
            ValueError: If *order* is not ``"dfs"`` or ``"bfs"``.
        """
        ...

    def find(self, *types: type[Expression] | str) -> Expression | None:
        """Find the first descendant matching any of *types* (DFS, skips self).

        Args:
            *types: One or more ``Expression`` subclasses (e.g. ``Column``)
                    or snake-case kind strings (e.g. ``"column"``).

        Returns:
            The first matching descendant, or ``None``.

        Example::

            ast = polyglot_sql.parse_one("SELECT a, 1 FROM t")
            ast.find(polyglot_sql.Column)          # Column(a)
            ast.find("literal")                    # Literal(1)
            ast.find(polyglot_sql.Column, polyglot_sql.Literal)  # Column(a) — first match
        """
        ...

    def find_all(self, *types: type[Expression] | str) -> list[Expression]:
        """Find all descendants matching any of *types* (DFS, skips self).

        Same argument format as :meth:`find`.
        """
        ...

    def unnest(self) -> Expression:
        """Recursively unwrap ``Paren`` wrappers. Returns self if not a ``Paren``."""
        ...

    def unalias(self) -> Expression:
        """Unwrap one ``Alias`` layer. Returns self if not an ``Alias``."""
        ...

    def flatten(self) -> list[Expression]:
        """Flatten same-variant chains into a list.

        For example, ``And(And(a, b), c)`` flattens to ``[a, b, c]``.
        Useful for normalizing chained ``AND`` / ``OR`` predicates.
        """
        ...

    def iter_expressions(self) -> list[Expression]:
        """Alias for :meth:`children` (sqlglot compatibility)."""
        ...

    def text(self, key: str) -> str:
        """Extract a field as a plain string.

        Looks up *key* in the serialized payload and returns:
        - Strings and numbers directly
        - Nested expressions via their :attr:`name`
        - Nested structs (e.g. ``Identifier``) via their ``name`` field
        - ``""`` for missing keys
        """
        ...


